# ---- Garmin Connect (unofficial session auth - works immediately) ----
GARMIN_EMAIL=your_garmin_account_email
GARMIN_PASSWORD=your_garmin_account_password

# ---- Official Garmin Health API (OAuth 1.0a - fill in once Garmin approves) ----
# Request access at https://developer.garmin.com/health-api/overview/
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# ---- Claude API (AI assistant) ----
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---- Units: "imperial" (miles) or "metric" (km) ----
UNITS=imperial
